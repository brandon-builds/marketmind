# ============================================================
# MarketMind - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file -- it is already in .gitignore.
# ============================================================

# Database
# MySQL-compatible connection string (TiDB Cloud free tier works great)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/marketmind

# OpenAI
# Required for the Research Agent (GPT-4o) and all AI features.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Session Security
# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-string

# Optional: FRED Macro Data
# Free API key for Federal Reserve macro indicators (GDP, CPI, yield curve, etc.)
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Optional: Manus OAuth (Authentication)
# Only needed if you want user login via Manus OAuth.
# The app is fully public-facing without these.
VITE_APP_ID=your_manus_app_id
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im/oauth/portal
OWNER_OPEN_ID=your_manus_owner_open_id

# Optional: Manus Forge API (LLM Fallback)
# Fallback LLM proxy if OPENAI_API_KEY is not set.
BUILT_IN_FORGE_API_URL=https://api.manus.im/forge
BUILT_IN_FORGE_API_KEY=your_forge_api_key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge
VITE_FRONTEND_FORGE_API_KEY=your_forge_frontend_api_key
